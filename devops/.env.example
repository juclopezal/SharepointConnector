# ── Azure AD App Registration ────────────────────────────────────────────────
# Required permissions: Sites.Read.All, Sites.ReadWrite.All
TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLIENT_SECRET=your-client-secret

# ── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
# Directory for the persistent rotating log file (in addition to console).
# Leave empty to log to console only.
LOG_DIR=
LOG_FILE=api_server_sp_connector.log

# ── Runtime ──────────────────────────────────────────────────────────────────
# Host port mapped to the container's internal port 8003.
SP_PORT=8003
